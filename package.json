{
  "name": "overnight-newsroom",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "services/ingestion",
    "apps/public-site"
  ],
  "scripts": {
    "convex:dev": "convex dev",
    "convex:codegen": "CONVEX_AGENT_MODE=anonymous npx convex dev --once",
    "convex:deploy": "convex deploy",
    "svc:build": "cd services/ingestion && npm run build",
    "svc:test": "cd services/ingestion && npm run test",
    "svc:poll": "cd services/ingestion && node dist/poller.js",
    "svc:enrich": "cd services/ingestion && node dist/enricher.js",
    "web:dev": "cd apps/public-site && npm run dev",
    "web:build": "npm run convex:codegen && cd apps/public-site && npm run build",
    "web:preview": "cd apps/public-site && npm run preview",
    "web:test": "cd apps/public-site && npm run test",
    "web:lint": "cd apps/public-site && npm run lint",
    "test": "npm run svc:test && npm run web:test",
    "evals:editorial": "npx tsx services/evals/editorial.eval.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/credential-providers": "^3.1081.0",
    "convex": "^1.42.1"
  },
  "devDependencies": {
    "dotenv": "^17.4.2"
  }
}
