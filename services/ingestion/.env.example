# Overnight Newsroom — Environment File
# Copy this to /etc/newsroom.env and fill in values.
# chmod 600 /etc/newsroom.env
#
# NEVER commit /etc/newsroom.env to git.

# Convex deployment URL (required)
CONVEX_URL=https://<your-deployment>.convex.cloud

# Shared secret for Convex mutation auth (required)
# Generate: openssl rand -hex 32
INGESTION_API_SECRET=<random-secret>

# Hermes API server (OpenAI-compatible)
HERMES_BASE_URL=http://localhost:8642/v1
HERMES_API_KEY=<bearer-token>
HERMES_MODEL=hermes-agent
HERMES_TIMEOUT_MS=45000

# Token pricing (USD per 1M tokens)
HERMES_INPUT_USD_PER_1M_TOKENS=0.0
HERMES_OUTPUT_USD_PER_1M_TOKENS=0.0

# Summary prompt versioning
SUMMARY_PROMPT_VERSION=rss-summary-v1

# Enricher loop controls
ENRICHER_POLL_INTERVAL_MS=60000
ENRICHER_MAX_PER_HOUR=30
ENRICHER_CLAIM_MAX=3
