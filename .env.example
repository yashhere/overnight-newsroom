# Overnight Newsroom — environment variables (no secrets here)
# Copy this to .env.local and fill in the values.

# ── Convex ─────────────────────────────────────────────────────────
CONVEX_DEPLOYMENT=dev:compassionate-dalmatian-323
CONVEX_URL=http://127.0.0.1:3210

# ── Public site ────────────────────────────────────────────────────
VITE_CONVEX_URL=http://127.0.0.1:3210

# ── Ingestion API secret (shared between Convex and OCI services) ──
INGESTION_API_SECRET=

# ── LLM Provider (openai or hermes) ─────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=120000
OPENAI_API_KEY=

# ── Hermes (fallback when LLM_PROVIDER=hermes) ────────────────────
HERMES_BASE_URL=http://localhost:8642/v1
HERMES_API_KEY=
HERMES_MODEL=hermes-agent
HERMES_TIMEOUT_MS=90000
HERMES_INPUT_USD_PER_1M_TOKENS=0
HERMES_OUTPUT_USD_PER_1M_TOKENS=0
SUMMARY_PROMPT_VERSION=rss-summary-v1

# ── Enricher (optional tuning) ─────────────────────────────────────
ENRICHER_CLAIM_MAX=3
ENRICHER_MAX_PER_HOUR=30
ENRICHER_POLL_INTERVAL_MS=60000

# ── Judge (ONR-005 — uses same Hermes vars above) ──────────────────
# LINKUP_API_KEY=          # needed for external corroboration (optional)

# ── Audio / ElevenLabs (ONR-006) ───────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_A=21m00Tcm4TlvDq8ikWAM   # Rachel (default)
ELEVENLABS_VOICE_ID_B=AZnzlk1XvdvUeBnXmlld   # Domi (default)
